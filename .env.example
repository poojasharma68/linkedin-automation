# ---- Core ----
NODE_ENV=production
PORT=3000

# Masters Union links API (screenshot uploads)
LINKS_API_BASE_URL=https://api.mastersunion.org/api

# ---- Puppeteer ----
PUPPETEER_HEADLESS=true
PUPPETEER_TIMEOUT_MS=120000
# Sessions + browser data live under the PARENT of this path. On Railway, mount
# a persistent volume at /app/browser-profile so this survives redeploys.
LINKEDIN_BROWSER_PROFILE_PATH=./browser-profile/linkedin

# ---- Auth ----
# Signs login tokens AND derives each user's extension key. Keep it secret and
# stable — changing it logs everyone out and invalidates every extension key.
ADMIN_JWT_SECRET=change-me-to-a-long-random-string

# Multi-user login. JSON array, one entry per person. Each connects their OWN
# LinkedIn. If you omit APP_USERS, only the single ADMIN_USERNAME below works.
APP_USERS=[{"username":"pooja","password":"set-a-strong-password"},{"username":"raj","password":"set-a-strong-password"}]

# Fallback single account (used only when APP_USERS is not set)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Encrypts each user's stored LinkedIn cookies at rest. Defaults to
# ADMIN_JWT_SECRET if unset, but set a dedicated random value in production.
SESSION_ENCRYPTION_KEY=another-long-random-string
