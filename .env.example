# Server
NODE_ENV=development
PORT=3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/linkedin-posts

# Masters Union links API (active upload target — POSTs the screenshot and
# returns the CDN url). Override only if the API moves; default is correct.
LINKS_API_BASE_URL=https://api.mastersunion.org/api

# Puppeteer / LinkedIn browser profile
PUPPETEER_HEADLESS=true
PUPPETEER_TIMEOUT_MS=120000
LINKEDIN_BROWSER_PROFILE_PATH=./browser-profile/linkedin

# Cron (processes any leftover Pending queue items)
CRON_SCHEDULE=*/5 * * * *
CRON_ENABLED=false

# Admin panel login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
ADMIN_JWT_SECRET=use-a-long-random-secret-at-least-32-chars
